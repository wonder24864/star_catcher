// Star Catcher - Prisma Schema
// Source of truth for all data models (see docs/adr/002-prisma-source-of-truth.md)
//
// Soft-delete convention: User, Family, ErrorQuestion have deletedAt fields.
// All queries MUST filter WHERE deletedAt IS NULL.
// Use Prisma Client Extensions ($extends) to inject this globally.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Users & Auth ====================

model User {
  id             String    @id @default(cuid())
  username       String    @unique @db.VarChar(32)
  password       String    @db.VarChar(128) // bcrypt hashed
  nickname       String    @db.VarChar(32)
  role           UserRole
  grade          Grade?    // Required for STUDENT role
  locale         Locale    @default(zh)
  isActive       Boolean   @default(true)
  deletedAt      DateTime? @db.Timestamptz // Soft delete
  loginFailCount Int       @default(0) // Consecutive login failures
  lockedUntil    DateTime? @db.Timestamptz // Account lock expiry
  createdAt      DateTime  @default(now()) @db.Timestamptz
  updatedAt      DateTime  @updatedAt @db.Timestamptz

  familyMemberships FamilyMember[]
  homeworkSessions  HomeworkSession[]
  errorQuestions    ErrorQuestion[]
  parentNotes       ParentNote[]
  adminLogs         AdminLog[]
  parentConfigs     ParentStudentConfig[] @relation("ParentConfigs")
  studentConfigs    ParentStudentConfig[] @relation("StudentConfigs")
  masteryStates     MasteryState[]        @relation("StudentMastery")
  reviewSchedules   ReviewSchedule[]      @relation("StudentReview")
  interventions     InterventionHistory[] @relation("StudentIntervention")
  agentTraces       AgentTrace[]

  @@index([username])
  @@index([role])
}

enum UserRole {
  STUDENT
  PARENT
  ADMIN
}

enum Grade {
  PRIMARY_1
  PRIMARY_2
  PRIMARY_3
  PRIMARY_4
  PRIMARY_5
  PRIMARY_6
  JUNIOR_1
  JUNIOR_2
  JUNIOR_3
  SENIOR_1
  SENIOR_2
  SENIOR_3
}

enum Locale {
  zh
  en
}

// ==================== Family Groups ====================

model Family {
  id                  String    @id @default(cuid())
  name                String    @db.VarChar(32)
  inviteCode          String?   @unique @db.VarChar(8)
  inviteCodeExpiresAt DateTime? @db.Timestamptz
  deletedAt           DateTime? @db.Timestamptz // Soft delete
  createdAt           DateTime  @default(now()) @db.Timestamptz
  updatedAt           DateTime  @updatedAt @db.Timestamptz

  members FamilyMember[]

  @@index([inviteCode])
}

model FamilyMember {
  id       String           @id @default(cuid())
  userId   String
  familyId String
  role     FamilyMemberRole
  joinedAt DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id])
  family Family @relation(fields: [familyId], references: [id])

  @@unique([userId, familyId])
  @@index([familyId])
  @@index([userId])
}

enum FamilyMemberRole {
  OWNER
  MEMBER
}

// ==================== Homework Check ====================

model HomeworkSession {
  id          String         @id @default(cuid())
  studentId   String
  createdBy   String         // Operator ID (could be parent acting on behalf)
  subject     Subject?       // AI auto-detected, user can override
  contentType ContentType?   // AI auto-detected
  grade       Grade?         // AI auto-detected
  title       String?        @db.VarChar(128)
  status      HomeworkStatus @default(CREATED)
  finalScore  Float?         // Written on completion
  totalRounds Int            @default(0)
  createdAt   DateTime       @default(now()) @db.Timestamptz
  updatedAt   DateTime       @updatedAt @db.Timestamptz

  student      User              @relation(fields: [studentId], references: [id])
  images       HomeworkImage[]
  checkRounds  CheckRound[]
  questions    SessionQuestion[]
  helpRequests HelpRequest[]

  @@index([studentId, createdAt])
  @@index([studentId, status])
  @@index([status, createdAt]) // Admin stats queries
}

enum Subject {
  MATH
  CHINESE
  ENGLISH
  PHYSICS
  CHEMISTRY
  BIOLOGY
  POLITICS
  HISTORY
  GEOGRAPHY
  OTHER
}

enum ContentType {
  EXAM
  HOMEWORK
  DICTATION
  COPYWRITING
  ORAL_CALC
  COMPOSITION
  OTHER
}

enum HomeworkStatus {
  CREATED
  RECOGNIZING
  RECOGNIZED
  RECOGNITION_FAILED
  CHECKING
  COMPLETED
}

model HomeworkImage {
  id               String   @id @default(cuid())
  homeworkSessionId String
  imageUrl         String   // MinIO URL
  originalFilename String?
  sortOrder        Int      @default(0)
  exifRotation     Int      @default(0) // EXIF orientation correction (0/90/180/270)
  privacyStripped  Boolean  @default(false) // GPS/privacy EXIF data stripped
  createdAt        DateTime @default(now())

  homeworkSession HomeworkSession @relation(fields: [homeworkSessionId], references: [id], onDelete: Cascade)

  @@index([homeworkSessionId])
}

model SessionQuestion {
  id               String        @id @default(cuid())
  homeworkSessionId String
  questionNumber   Int
  questionType     QuestionType?
  content          String        @db.Text
  studentAnswer    String?       @db.Text
  correctAnswer    String?       @db.Text
  isCorrect        Boolean?
  confidence       Float?        // AI confidence 0.0-1.0
  needsReview      Boolean       @default(false) // Flagged when confidence < 0.7
  imageRegion      Json?         // Relative coords {x%, y%, w%, h%}
  aiKnowledgePoint String?       @db.VarChar(256)
  createdAt        DateTime      @default(now()) @db.Timestamptz
  updatedAt        DateTime      @updatedAt @db.Timestamptz

  homeworkSession HomeworkSession       @relation(fields: [homeworkSessionId], references: [id], onDelete: Cascade)
  roundResults    RoundQuestionResult[]
  helpRequests    HelpRequest[]
  errorQuestion   ErrorQuestion?

  @@index([homeworkSessionId])
}

enum QuestionType {
  CHOICE
  FILL_BLANK
  TRUE_FALSE
  SHORT_ANSWER
  CALCULATION
  ESSAY
  DICTATION_ITEM
  COPY_ITEM
  OTHER
}

model CheckRound {
  id               String   @id @default(cuid())
  homeworkSessionId String
  roundNumber      Int
  score            Float?
  totalQuestions   Int?
  correctCount     Int?
  createdAt        DateTime @default(now())

  homeworkSession HomeworkSession       @relation(fields: [homeworkSessionId], references: [id], onDelete: Cascade)
  results         RoundQuestionResult[]

  @@unique([homeworkSessionId, roundNumber])
  @@index([homeworkSessionId])
}

model RoundQuestionResult {
  id                String  @id @default(cuid())
  checkRoundId      String
  sessionQuestionId String
  studentAnswer     String? // Answer in this round
  isCorrect         Boolean
  correctedFromPrev Boolean @default(false)

  checkRound      CheckRound      @relation(fields: [checkRoundId], references: [id], onDelete: Cascade)
  sessionQuestion SessionQuestion @relation(fields: [sessionQuestionId], references: [id], onDelete: Cascade)

  @@index([checkRoundId])
  @@index([sessionQuestionId])
}

model HelpRequest {
  id               String   @id @default(cuid())
  homeworkSessionId String
  sessionQuestionId String
  level            Int      // 1, 2, or 3
  aiResponse       String   // AI-generated help content
  createdAt        DateTime @default(now())

  homeworkSession HomeworkSession @relation(fields: [homeworkSessionId], references: [id], onDelete: Cascade)
  sessionQuestion SessionQuestion @relation(fields: [sessionQuestionId], references: [id], onDelete: Cascade)

  @@index([homeworkSessionId])
  @@index([sessionQuestionId])
}

// ==================== Error Notebook ====================

model ErrorQuestion {
  id                String       @id @default(cuid())
  studentId         String
  sessionQuestionId String?      @unique
  subject           Subject
  contentType       ContentType?
  grade             Grade?
  questionType      QuestionType?
  content           String       @db.Text
  contentHash       String?      @db.VarChar(64) // SHA256 for dedup (see ADR-005)
  studentAnswer     String?      @db.Text
  correctAnswer     String?      @db.Text
  errorAnalysis     String?      @db.Text // AI error analysis
  aiKnowledgePoint  String?      @db.VarChar(256)
  imageUrl          String?
  totalAttempts     Int          @default(1)
  correctAttempts   Int          @default(0)
  isMastered        Boolean      @default(false)
  deletedAt         DateTime?    @db.Timestamptz // Soft delete
  createdAt         DateTime     @default(now()) @db.Timestamptz
  updatedAt         DateTime     @updatedAt @db.Timestamptz

  student           User              @relation(fields: [studentId], references: [id])
  sessionQuestion   SessionQuestion?  @relation(fields: [sessionQuestionId], references: [id])
  parentNotes       ParentNote[]
  knowledgeMappings QuestionKnowledgeMapping[]

  @@unique([studentId, contentHash])
  @@index([studentId, subject])
  @@index([studentId, createdAt])
  @@index([studentId, isMastered])
  @@index([studentId, deletedAt, createdAt])  // Soft-delete filtered list queries
}

model ParentNote {
  id              String   @id @default(cuid())
  parentId        String
  errorQuestionId String
  content         String   @db.VarChar(500)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  parent        User          @relation(fields: [parentId], references: [id])
  errorQuestion ErrorQuestion @relation(fields: [errorQuestionId], references: [id], onDelete: Cascade)

  @@index([errorQuestionId])
}

// ==================== Parent Settings ====================

model ParentStudentConfig {
  id           String   @id @default(cuid())
  parentId     String
  studentId    String
  parent       User     @relation("ParentConfigs", fields: [parentId], references: [id])
  student      User     @relation("StudentConfigs", fields: [studentId], references: [id])
  maxHelpLevel Int      @default(2) // Max help level (1-3), default 2 for elementary
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([parentId, studentId])
  @@index([parentId])  // "get all students for this parent"
  @@index([studentId]) // "get all parents for this student"
}

// ==================== System Admin ====================

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  details   Json?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ==================== Skill Plugin System ====================
// See docs/adr/008-agent-architecture.md

model SkillDefinition {
  id             String      @id @default(cuid())
  name           String      @db.VarChar(64)  // kebab-case identifier
  version        String      @db.VarChar(16)  // semver (e.g. 1.0.0)
  description    String      @db.VarChar(500)
  author         String      @db.VarChar(100)
  functionSchema Json        // Canonical JSON Schema (provider-agnostic)
  bundleUrl      String?     @db.VarChar(512) // MinIO bundle path
  config         Json?       // Skill-specific config (timeout, cache TTL, etc.)
  status         SkillStatus @default(DRAFT)
  callCount      Int         @default(0)
  avgDurationMs  Float       @default(0)
  deletedAt      DateTime?   @db.Timestamptz // Soft delete (ADR-008)
  createdAt      DateTime    @default(now()) @db.Timestamptz
  updatedAt      DateTime    @updatedAt @db.Timestamptz

  @@unique([name, version])
  @@index([status])
  @@index([name])
  @@index([deletedAt, status]) // Soft-delete filtered queries
}

enum SkillStatus {
  DRAFT
  ACTIVE
  DISABLED
  DEPRECATED
}

// ==================== Knowledge Graph ====================
// See docs/adr/009-knowledge-graph-storage.md

enum SchoolLevel {
  PRIMARY   // 小学
  JUNIOR    // 初中
  SENIOR    // 高中
}

enum KnowledgeRelationType {
  PREREQUISITE // 前置依赖（from 是 to 的前置）
  PARALLEL     // 平行关系（同级并列知识点）
  CONTAINS     // 包含关系（from 包含 to）
}

enum KnowledgeMappingSource {
  AI_DETECTED     // AI 自动标注
  ADMIN_VERIFIED  // 管理员人工确认
}

model KnowledgePoint {
  id              String      @id @default(cuid())
  externalId      String?     @unique @db.VarChar(128) // 教材版本标识
  subject         Subject
  grade           Grade?      // 某些知识点跨年级
  schoolLevel     SchoolLevel
  name            String      @db.VarChar(128)
  description     String?     @db.Text
  parentId        String?     // 自引用，树形层级
  depth           Int         @default(0) // 层级深度（0=学科根节点）
  difficulty      Int         @default(3) @db.SmallInt // 1-5
  importance      Int         @default(3) @db.SmallInt // 1-5
  examFrequency   Int         @default(3) @db.SmallInt // 1-5
  metadata        Json?       // 灵活扩展属性
  // embedding    Unsupported("vector(1536)")? // pgvector — Task 50 启用
  createdAt       DateTime    @default(now()) @db.Timestamptz
  updatedAt       DateTime    @updatedAt @db.Timestamptz
  deletedAt       DateTime?   @db.Timestamptz

  parent          KnowledgePoint?  @relation("KnowledgePointTree", fields: [parentId], references: [id])
  children        KnowledgePoint[] @relation("KnowledgePointTree")
  relationsFrom   KnowledgeRelation[] @relation("RelationFrom")
  relationsTo     KnowledgeRelation[] @relation("RelationTo")
  questionMappings  QuestionKnowledgeMapping[]
  masteryStates     MasteryState[]
  reviewSchedules   ReviewSchedule[]
  interventions     InterventionHistory[]

  @@index([subject, schoolLevel])
  @@index([parentId])
  @@index([deletedAt, subject]) // Soft-delete filtered queries
}

model KnowledgeRelation {
  id          String                @id @default(cuid())
  fromPointId String
  toPointId   String
  type        KnowledgeRelationType
  strength    Float                 @default(1.0) // 0.0-1.0 关系强度
  createdAt   DateTime              @default(now()) @db.Timestamptz

  fromPoint   KnowledgePoint @relation("RelationFrom", fields: [fromPointId], references: [id], onDelete: Cascade)
  toPoint     KnowledgePoint @relation("RelationTo", fields: [toPointId], references: [id], onDelete: Cascade)

  @@unique([fromPointId, toPointId, type])
  @@index([fromPointId, type])
  @@index([toPointId, type])
}

model QuestionKnowledgeMapping {
  id               String                 @id @default(cuid())
  questionId       String
  knowledgePointId String
  mappingSource    KnowledgeMappingSource @default(AI_DETECTED)
  confidence       Float                  @default(0.8) // 0.0-1.0
  createdAt        DateTime               @default(now()) @db.Timestamptz

  question         ErrorQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  knowledgePoint   KnowledgePoint @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)

  @@unique([questionId, knowledgePointId])
  @@index([knowledgePointId])
  @@index([questionId])
}

// ==================== Student Memory ====================
// See docs/adr/010-student-memory-layer.md

enum MasteryStatus {
  NEW_ERROR   // 首次出错，错题入本
  CORRECTED   // 改正流程中答对
  REVIEWING   // 间隔复习阶段
  MASTERED    // 连续通过 N 次复习
  REGRESSED   // 已掌握后再次出错
}

enum InterventionType {
  DIAGNOSIS    // AI 诊断
  HINT         // 提示
  REVIEW       // 复习
  EXPLANATION  // 讲解
}

model MasteryState {
  id               String        @id @default(cuid())
  studentId        String
  knowledgePointId String
  status           MasteryStatus @default(NEW_ERROR)
  totalAttempts    Int           @default(1)
  correctAttempts  Int           @default(0)
  lastAttemptAt    DateTime?     @db.Timestamptz
  masteredAt       DateTime?     @db.Timestamptz
  version          Int           @default(1) // 乐观锁
  createdAt        DateTime      @default(now()) @db.Timestamptz
  updatedAt        DateTime      @updatedAt @db.Timestamptz

  student        User           @relation("StudentMastery", fields: [studentId], references: [id])
  knowledgePoint KnowledgePoint @relation(fields: [knowledgePointId], references: [id])

  @@unique([studentId, knowledgePointId])
  @@index([studentId, status])
  @@index([knowledgePointId])
}

model ReviewSchedule {
  id                 String   @id @default(cuid())
  studentId          String
  knowledgePointId   String
  nextReviewAt       DateTime @db.Timestamptz
  intervalDays       Int      @default(1)
  easeFactor         Float    @default(2.5) // SM-2 算法参数
  consecutiveCorrect Int      @default(0)
  createdAt          DateTime @default(now()) @db.Timestamptz
  updatedAt          DateTime @updatedAt @db.Timestamptz

  student        User           @relation("StudentReview", fields: [studentId], references: [id])
  knowledgePoint KnowledgePoint @relation(fields: [knowledgePointId], references: [id])

  @@unique([studentId, knowledgePointId])
  @@index([studentId, nextReviewAt])
  @@index([knowledgePointId])
}

model InterventionHistory {
  id               String           @id @default(cuid())
  studentId        String
  knowledgePointId String
  type             InterventionType
  content          Json?            // 干预详情
  agentId          String?          @db.VarChar(64) // 来源 Agent
  skillId          String?          @db.VarChar(64) // 来源 Skill
  createdAt        DateTime         @default(now()) @db.Timestamptz

  student        User           @relation("StudentIntervention", fields: [studentId], references: [id])
  knowledgePoint KnowledgePoint @relation(fields: [knowledgePointId], references: [id])

  @@index([studentId, knowledgePointId, createdAt])
  @@index([studentId, type])
}

// ==================== Agent Execution Trace ====================
// See docs/adr/008-agent-architecture.md §6

enum AgentTraceStatus {
  RUNNING
  COMPLETED
  TERMINATED
  FAILED
}

enum AgentTraceTerminationReason {
  COMPLETED        // AI decided to stop
  MAX_STEPS        // Hit maxSteps limit
  MAX_TOKENS       // Hit token budget
  SKILL_ALL_FAILED // All skill calls in a step failed
  ERROR            // Unrecoverable error
}

enum AgentTraceStepStatus {
  SUCCESS
  FAILED
  TIMEOUT
}

model AgentTrace {
  id                 String                       @id @default(cuid())
  agentName          String                       @db.VarChar(64)
  sessionId          String                       @db.VarChar(64)
  userId             String
  status             AgentTraceStatus             @default(RUNNING)
  totalSteps         Int                          @default(0)
  totalInputTokens   Int                          @default(0)
  totalOutputTokens  Int                          @default(0)
  totalDurationMs    Int                          @default(0)
  terminationReason  AgentTraceTerminationReason?
  summary            String?                      @db.Text // AI-generated execution summary
  createdAt          DateTime                     @default(now()) @db.Timestamptz
  completedAt        DateTime?                    @db.Timestamptz

  user  User             @relation(fields: [userId], references: [id])
  steps AgentTraceStep[]

  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([agentName, createdAt])
  @@index([status])
}

model AgentTraceStep {
  id           String               @id @default(cuid())
  traceId      String
  stepNo       Int
  skillName    String               @db.VarChar(64)
  input        Json                 // JSONB
  output       Json?                // JSONB
  inputTokens  Int                  @default(0)
  outputTokens Int                  @default(0)
  durationMs   Int                  @default(0)
  status       AgentTraceStepStatus
  errorMessage String?              @db.Text
  createdAt    DateTime             @default(now()) @db.Timestamptz

  trace AgentTrace @relation(fields: [traceId], references: [id], onDelete: Cascade)

  @@index([traceId, stepNo])
  @@index([traceId])
}

// ==================== AI Call Logging ====================
// All AI calls are logged via the Harness CallLogger (see ADR-001)

enum AIOperationType {
  OCR_RECOGNIZE
  SUBJECT_DETECT
  HELP_GENERATE
  GRADE_ANSWER
}

model AICallLog {
  id            String          @id @default(cuid())
  userId        String?
  operationType AIOperationType
  provider      String          @db.VarChar(16) // azure / local
  model         String          @db.VarChar(32) // gpt-5.4
  correlationId String?         @db.VarChar(64) // BullMQ jobId or tRPC requestId
  inputTokens   Int             @default(0)
  outputTokens  Int             @default(0)
  durationMs    Int             @default(0)
  success       Boolean
  errorMessage  String?         @db.Text
  createdAt     DateTime        @default(now()) @db.Timestamptz

  @@index([createdAt])
  @@index([operationType])
  @@index([userId, createdAt])
}
