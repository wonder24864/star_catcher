# ===================================================================
# Star Catcher — Production Environment
# ===================================================================
# 1. Copy to .env:   cp .env.prod.example .env
# 2. Fill all CHANGE_ME values with generated secrets
# 3. chmod 600 .env
# ===================================================================

# ── Docker Image ──────────────────────────────────────────────────
# Git short hash from build (e.g., a1b2c3d)
IMAGE_TAG=latest

# ── Exposed Ports ────────────────────────────────────────────────
# App and MinIO external ports. Change here if NAS has port conflicts.
# Leave blank/unset for defaults (app:3000, minio:9000). The compose file
# automatically wires NEXTAUTH_URL and MinIO presigned URLs to these ports.
APP_PORT=3000
MINIO_PORT=9000

# ── Tailscale ─────────────────────────────────────────────────────
# NAS Tailscale hostname or IP (e.g., nas.tail1234.ts.net or 100.x.x.x)
# Run `tailscale status` on NAS to find it
NAS_TAILSCALE_HOSTNAME=CHANGE_ME

# ── Database ──────────────────────────────────────────────────────
# Generate: openssl rand -hex 24  (hex keeps password URL-safe; base64 may
# produce `/` or `+` which breaks DATABASE_URL parsing when embedded in URL)
DB_PASSWORD=CHANGE_ME

# ── MinIO (S3 Storage) ───────────────────────────────────────────
# Generate access key: openssl rand -hex 16
# Generate secret key: openssl rand -base64 32
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=star-catcher

# ── Azure OpenAI ─────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=CHANGE_ME
AZURE_OPENAI_ENDPOINT=CHANGE_ME
AZURE_OPENAI_DEPLOYMENT=CHANGE_ME
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── NextAuth ─────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Star Catcher
NEXT_PUBLIC_DEFAULT_LOCALE=zh
# Generate: openssl rand -base64 12
ADMIN_DEFAULT_PASSWORD=CHANGE_ME

# ── Embedding Provider ───────────────────────────────────────────
# For SemanticCache. Defaults reuse AZURE_OPENAI_* when *_ENDPOINT/*_API_KEY empty.
# Set EMBEDDING_DEPLOYMENT to the name of your Azure embedding deployment.
EMBEDDING_PROVIDER=azure
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DEPLOYMENT=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# EMBEDDING_ENDPOINT and EMBEDDING_API_KEY: leave empty to fallback to AZURE_OPENAI_*

# ── Semantic Cache (optional, saves AI cost) ─────────────────────
# Enable only if EMBEDDING_DEPLOYMENT points to an existing Azure embedding deployment.
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_TTL_HOURS=168
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.95

# ── OpenTelemetry (optional) ─────────────────────────────────────
# Enable to export traces to an OTLP collector (e.g., self-hosted Jaeger, Honeycomb).
# prod compose has no Jaeger service; set your own collector URL when enabling.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# Jaeger UI URL (Sprint 15 — leave empty if Jaeger not deployed)
JAEGER_UI_URL=

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Database / Seed 运维 ──────────────────────────────────────────
# RUN_MIGRATE 由 docker-compose.prod.yml 固定为 1，每次启动自动 prisma migrate deploy
# （此变量不从 .env 读取；如需关闭请直接改 compose 文件）
# RUN_SEED 仅首次部署时在 docker compose up 命令前加 `RUN_SEED=1` 环境变量，
# 用于创建初始 admin 账号（密码取自 ADMIN_DEFAULT_PASSWORD）

# ── 数据卷路径 ────────────────────────────────────────────────────
# 数据写入该路径下的 pgdata/redisdata/miniodata 三个子目录
# 默认 ./data 相对于 compose 文件所在目录，Docker 首次启动会自动创建
# 如果 NAS UI 把 compose 当字符串存（不走文件系统），改成绝对路径
# 示例：DATA_PATH_PREFIX=/volume1/docker/star-catcher/data
DATA_PATH_PREFIX=./data

# ── 容器资源限制 ──────────────────────────────────────────────────
# 单位支持 512M / 1G / 2G 等；Brain + embedding 批处理建议放宽
APP_MEM=1G
WORKER_MEM=1G
DB_MEM=1G
REDIS_MEM=512M
MINIO_MEM=512M
# Redis 内部 eviction 阈值（建议为 REDIS_MEM 的 50-75%）
REDIS_MAXMEMORY=256mb

# ── Worker 并发 ───────────────────────────────────────────────────
# BullMQ Worker 并发数；机器/AI quota 吃紧时降低
WORKER_CONCURRENCY=3
