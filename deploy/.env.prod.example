# ===================================================================
# Star Catcher — Production Environment
# ===================================================================
# 1. Copy to .env:   cp .env.prod.example .env
# 2. Fill all CHANGE_ME values with generated secrets
# 3. chmod 600 .env
# ===================================================================

# ── Docker Image ──────────────────────────────────────────────────
# Git short hash from build (e.g., a1b2c3d)
IMAGE_TAG=latest

# ── Tailscale ─────────────────────────────────────────────────────
# NAS Tailscale hostname or IP (e.g., nas.tail1234.ts.net or 100.x.x.x)
# Run `tailscale status` on NAS to find it
NAS_TAILSCALE_HOSTNAME=CHANGE_ME

# ── Database ──────────────────────────────────────────────────────
# Generate: openssl rand -base64 24
DB_PASSWORD=CHANGE_ME

# ── MinIO (S3 Storage) ───────────────────────────────────────────
# Generate access key: openssl rand -hex 16
# Generate secret key: openssl rand -base64 32
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=star-catcher

# ── Azure OpenAI ─────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=CHANGE_ME
AZURE_OPENAI_ENDPOINT=CHANGE_ME
AZURE_OPENAI_DEPLOYMENT=CHANGE_ME
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── NextAuth ─────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Star Catcher
NEXT_PUBLIC_DEFAULT_LOCALE=zh
# Generate: openssl rand -base64 12
ADMIN_DEFAULT_PASSWORD=CHANGE_ME

# ── Embedding Provider ───────────────────────────────────────────
# For SemanticCache. Defaults reuse AZURE_OPENAI_* when *_ENDPOINT/*_API_KEY empty.
# Set EMBEDDING_DEPLOYMENT to the name of your Azure embedding deployment.
EMBEDDING_PROVIDER=azure
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DEPLOYMENT=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# EMBEDDING_ENDPOINT and EMBEDDING_API_KEY: leave empty to fallback to AZURE_OPENAI_*

# ── Semantic Cache (optional, saves AI cost) ─────────────────────
# Enable only if EMBEDDING_DEPLOYMENT points to an existing Azure embedding deployment.
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_TTL_HOURS=168
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.95

# ── OpenTelemetry (optional) ─────────────────────────────────────
# Enable to export traces to an OTLP collector (e.g., self-hosted Jaeger, Honeycomb).
# prod compose has no Jaeger service; set your own collector URL when enabling.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=info
