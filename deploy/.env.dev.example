# Docker Compose project name (ALWAYS use this to avoid container conflicts)
COMPOSE_PROJECT_NAME=star-catcher

# Database
DATABASE_URL=postgresql://star_catcher:your_password@localhost:5432/star_catcher
DB_PASSWORD=your_password

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (File Storage)
MINIO_ENDPOINT=localhost
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=star-catcher

# Azure OpenAI
AI_PROVIDER=azure
AZURE_OPENAI_API_KEY=your_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Embedding Provider (for SemanticCache)
EMBEDDING_PROVIDER=azure
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DEPLOYMENT=text-embedding-3-small
EMBEDDING_ENDPOINT=                         # defaults to AZURE_OPENAI_ENDPOINT
EMBEDDING_API_KEY=                          # defaults to AZURE_OPENAI_API_KEY
EMBEDDING_DIMENSIONS=1536

# Semantic Cache
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_TTL_HOURS=168
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.95

# OpenTelemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Jaeger UI (Sprint 15 — Jaeger link in agent-traces page)
JAEGER_UI_URL=http://localhost:16686

# NextAuth
NEXTAUTH_SECRET=your_random_secret
NEXTAUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_APP_NAME=Star Catcher
NEXT_PUBLIC_DEFAULT_LOCALE=zh

# Admin (used by prisma db seed)
ADMIN_DEFAULT_PASSWORD=change_me_on_first_login
